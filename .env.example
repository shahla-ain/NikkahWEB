# ============================================================
#  NIKAH INVITE — ENVIRONMENT VARIABLES TEMPLATE
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git — it's already in .gitignore
# ============================================================

# ── Admin Credentials ─────────────────────────────────────
# The username used to log into /admin
ADMIN_USERNAME=admin

# bcrypt hash of your admin password.
# Generate with: node scripts/generate-hash.js
# Example (DO NOT use this — generate your own!):
# ADMIN_PASS_HASH=$2b$12$someRandomHashHere...
ADMIN_PASS_HASH=REPLACE_WITH_OUTPUT_OF_generate-hash_SCRIPT

# ── JWT Secret ────────────────────────────────────────────
# Random string, at least 32 characters.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_STRING

# ── Database (Optional) ───────────────────────────────────
# If not set, RSVP data is stored in memory (resets on cold start).
# Recommended: Supabase, PlanetScale, Railway, or Neon.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Site URL (for CORS & share links) ────────────────────
SITE_URL=https://your-site.netlify.app

# ── Email Notifications (Optional) ───────────────────────
# If you want to receive email on new RSVPs (add nodemailer support)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_app_password
# NOTIFY_EMAIL=couple@email.com
